      "spacing": "Generous (p-8, p-12)",
      "container": "max-w-7xl mx-auto px-4 md:px-8",
      "border_radius": "rounded-none (Sharp edges for 'Technical' feel) or rounded-sm"
    },
    "components": {
      "header": {
        "bg": "bg-black",
        "text": "text-white",
        "height": "h-20",
        "elements": [
          "Logo (Left, Bold, Uppercase)",
          "Nav (Center-Left, Hidden on Mobile)",
          "Icons (Right: Search, Heart, Cart, User)"
        ]
      },
      "product_card": {
        "style": "minimalist",
        "image_aspect": "aspect-[4/5]",
        "elements": [
          "Image (Dominant)",
          "Label (e.g., '1 COLOR' - Text XS, Muted)",
          "Title (Bold, Oswald, Uppercase)",
          "Price (Inter, Regular)",
          "Hover: Quick Add / Alternate View"
        ]
      },
      "buttons": {
        "primary": "bg-black text-white hover:bg-gray-800 rounded-none uppercase font-bold tracking-wider px-8 py-4",
        "secondary": "border border-black text-black hover:bg-black hover:text-white rounded-none uppercase font-bold tracking-wider px-8 py-4"
      },
      "filters": {
        "style": "Horizontal Bar",
        "position": "Sticky below header",
        "elements": "Dropdowns (Category, Size, Color, Price)"
