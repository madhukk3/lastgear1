  "implementation_rules": {
    "universal": [
      "Use 'data-testid' for all interactive elements.",
      "Do NOT use gradients. Stick to solid Black and White.",
      "Ensure text contrast meets WCAG AA.",
      "Use 'Oswald' font for all Headings (h1-h6).",
      "Use 'Inter' font for all body text.",
      "Buttons must be rectangular (sharp corners) to match the 'Technical' aesthetic.",
      "Header must be sticky.",
      "Product Grid: Use 'grid-cols-2 md:grid-cols-4' with 'gap-x-4 gap-y-12'."
    ],
    "pages": {
      "home": {
        "structure": [
          "Hero (Full width, Text Overlay 'LAST GEAR')",
          "Featured Categories (Bento Grid)",
          "New Arrivals (Carousel)",
          "Newsletter (Minimalist Black Section)"
        ]
      },
      "product_listing": {
        "structure": [
          "Header (Black)",
          "Title Bar (White, 'MEN's CLOTHING', Left Aligned)",
          "Filter Bar (Sticky, Dropdowns)",
          "Product Grid (Infinite Scroll or Pagination)"
        ]
      },
      "product_detail": {
        "structure": [
          "Split Layout: Left (Images Stacked), Right (Sticky Info)",
          "Size Selector: Boxed Buttons (No Dropdown)",
          "Add to Cart: Full Width Black Button"
        ]
      }
    }
